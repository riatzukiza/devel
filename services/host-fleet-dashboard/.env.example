HOST_FLEET_DASHBOARD_HOST=0.0.0.0
HOST_FLEET_DASHBOARD_PORT=8791
HOST_FLEET_DASHBOARD_AUTH_TOKEN=change-me-host-fleet-dashboard-token
HOST_FLEET_DASHBOARD_ALLOW_UNAUTHENTICATED=false
HOST_FLEET_REQUEST_TIMEOUT_MS=10000
HOST_FLEET_DOCKER_SOCKET_PATH=/var/run/docker.sock

# Set this per host.
# On ussy.promethean.rest use HOST_FLEET_SELF_TARGET_ID=ussy
# On ussy3.promethean.rest use HOST_FLEET_SELF_TARGET_ID=ussy3
HOST_FLEET_SELF_TARGET_ID=ussy

# Example for the production host.
HOST_FLEET_TARGETS_JSON=[{"id":"ussy","label":"ussy.promethean.rest","mode":"local","publicBaseUrl":"https://ussy.promethean.rest/fleet","routeFiles":["/workspace/services/proxx/Caddyfile"],"notes":"primary"},{"id":"ussy3","label":"ussy3.promethean.rest","mode":"remote-http","publicBaseUrl":"https://ussy3.promethean.rest/fleet","notes":"staging"}]
