VOICE_GATEWAY_HOST=0.0.0.0
VOICE_GATEWAY_PORT=8788
VOICE_GATEWAY_API_KEY=
VOICE_GATEWAY_DATA_DIR=./data
VOICE_GATEWAY_DEFAULT_AUDIO_FORMAT=mp3
VOICE_GATEWAY_DEFAULT_LANGUAGE=en
VOICE_GATEWAY_TTS_DEVICE=auto
VOICE_GATEWAY_TTS_EAGER_LOAD=0
VOICE_GATEWAY_TTS_BACKEND_ORDER=
