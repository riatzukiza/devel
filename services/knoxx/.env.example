# FutureSight KMS Stack Configuration
# Copy to .env and customize

# ============================================================
# Service Ports
# ============================================================
NGINX_HTTP_PORT=80
SHIBBOLETH_HTTP_PORT=8097
SHIBBOLETH_UI_URL=http://localhost:8097

# ============================================================
# API Keys
# ============================================================
RAGUSSY_API_KEY=change-me-ragussy
KM_LABELS_API_KEY=change-me-km-labels
PROXY_AUTH_TOKEN=${OPEN_HAX_OPENAI_PROXY_AUTH_TOKEN:-}
KNOXX_OPENPLANNER_API_KEY=change-me-openplanner
HF_TOKEN=
HUGGINGFACE_TOKEN=

# ============================================================
# Database
# ============================================================
POSTGRES_USER=kms
POSTGRES_PASSWORD=kms
POSTGRES_DB=futuresight_kms

# ============================================================
# Model / embedding config
# ============================================================
MODEL_LAB_OPENAI_API_KEY=${OPEN_HAX_OPENAI_PROXY_AUTH_TOKEN:-}
DEFAULT_THREADS=4
DEFAULT_CTX=4096
DEFAULT_GPU_LAYERS=-1
EMBED_MODE=local
EMBED_MODEL=bge-m3
EMBED_DIM=1024

# ============================================================
# Optional proxy override for Shibboleth MT/builds
# ============================================================
PROMPTBENCH_PROXY_URL=http://host.docker.internal:8789/v1/chat/completions

# ============================================================
# OpenPlanner integration
# ============================================================
KNOXX_OPENPLANNER_BASE_URL=http://nginx/api/openplanner
KNOXX_SESSION_PROJECT_NAME=knoxx-session
KNOXX_THINKING_LEVEL=off
KNOXX_REASONING_MODEL_PREFIXES=glm-

# ============================================================
# Path Overrides (for local development)
# ============================================================
# KM_LABELS_PATH=../../packages/futuresight-kms
# RAGUSSY_BACKEND_PATH=../../orgs/mojomast/ragussy/backend
# RAGUSSY_FRONTEND_PATH=../../orgs/mojomast/ragussy/frontend
# SHIBBOLETH_BACKEND_PATH=../../orgs/octave-commons/shibboleth
# Knoxx frontend proxy target (default = baked static frontend container)
# KNOXX_FRONTEND_UPSTREAM_HOST=knoxx-frontend
# KNOXX_FRONTEND_UPSTREAM_PORT=80
# For Vite dev mode via compose profile:
# COMPOSE_PROFILES=frontend-dev
# KNOXX_FRONTEND_UPSTREAM_HOST=knoxx-frontend-dev
# KNOXX_FRONTEND_UPSTREAM_PORT=5173
# To refresh baked UI assets, sync ../../orgs/octave-commons/shibboleth/ui/dist/ into
# services/futuresight-kms/vendor/shibboleth-ui-dist/ before rebuilding nginx.

# Proxy-backed model provider for Ragussy / Shibboleth
# PROXX_BASE_URL=http://proxx:8789
# PROXX_DEFAULT_MODEL=glm-5
# KNOXX_AGENT_DIR=/runs/knoxx-agent
# KNOXX_POLICY_DATABASE_URL=postgresql://kms:kms@postgres:5432/futuresight_kms  # pragma: allowlist secret
# KNOXX_PRIMARY_ORG_SLUG=open-hax
# KNOXX_PRIMARY_ORG_NAME=Open Hax
# KNOXX_PRIMARY_ORG_KIND=platform_owner
# KNOXX_BOOTSTRAP_SYSTEM_ADMIN_EMAIL=system-admin@open-hax.local
# KNOXX_BOOTSTRAP_SYSTEM_ADMIN_NAME=Knoxx System Admin
# PROXX_CONNECTION_TIMEOUT_MS=15000
# PROXX_SOCKET_TIMEOUT_MS=180000
# Export PROXY_AUTH_TOKEN in your shell before docker compose up.

# Run agent containers as the host user to prevent root-owned files
DOCKER_USER=1000:1000
