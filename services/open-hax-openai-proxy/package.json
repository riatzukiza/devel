{
  "name": "@workspace/open-hax-openai-proxy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "OpenAI-compatible chat proxy with provider account rotation.",
  "license": "GPL-3.0-only",
  "scripts": {
    "dev": "node --env-file-if-exists=.env --import tsx src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file-if-exists=.env dist/main.js",
    "test": "pnpm run build && node --test dist/tests/*.test.js",
    "web:dev": "vite --config web/vite.config.ts",
    "web:build": "vite build --config web/vite.config.ts",
    "web:preview": "vite preview --config web/vite.config.ts"
  },
  "dependencies": {
    "chromadb": "^3.2.2",
    "fastify": "^4.27.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "tsx": "^4.20.6",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
