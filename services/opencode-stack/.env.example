OPENCODE_PORT=8789
OPENCODE_ADMIN_PORT=4097
OPENCODE_RAW_PORT=4098

# Host bind mounts. These keep the container on the real workspace and the
# real host OpenCode database/state instead of an isolated container filesystem.
WORKSPACE_ROOT=/home/err/devel
HOST_OPENCODE_CONFIG_DIR=/home/err/.config/opencode
HOST_OPENCODE_DATA_DIR=/home/err/.local/share/opencode
HOST_OPENCODE_CACHE_DIR=/home/err/.cache/opencode
HOST_OPENCODE_STATE_DIR=/home/err/.local/state/opencode

# Optional. If Janus is reached through a host-published port instead of the
# shared Docker network, override the gateway upstream here.
# OPENCODE_GATEWAY_JANUS_URL=http://host.docker.internal:8790

# GitHub OAuth app credentials
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# Exact callback URL registered in the GitHub OAuth app.
# This should point at this stack's public gateway callback.
# Example:
# OAUTH_GITHUB_REDIRECT_URI=https://opencode.tailnet-name.ts.net/auth/oauth/callback
OAUTH_GITHUB_REDIRECT_URI=

# Optional public base URL used when deriving links and callback defaults.
# PUBLIC_BASE_URL=https://opencode.tailnet-name.ts.net

# Optional eta-mu protected mount on the same gateway.
# ETA_MU_BASE_PATH=/eta-mu
# ETA_MU_UPSTREAM_URL=http://host.docker.internal:8787

# Optional bootstrap list used only when the allowlist file does not exist yet.
# GITHUB_ALLOWED_USERS=your-login,another-login
