FROM node:22-bookworm-slim

RUN apt-get update \
  && apt-get install -y --no-install-recommends bash curl python3 python3-pip \
  && rm -rf /var/lib/apt/lists/*

RUN pip3 install --break-system-packages requests pyyaml matplotlib

WORKDIR /app
COPY hormuz-agent-loop.sh /app/hormuz-agent-loop.sh
RUN chmod +x /app/hormuz-agent-loop.sh

CMD ["/app/hormuz-agent-loop.sh"]
