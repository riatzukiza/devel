{
  "name": "@promethean-os/opencode-compat",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "OpenCode-compatible cloud harness scaffold with Neon-compatible Postgres storage.",
  "license": "GPL-3.0-only",
  "scripts": {
    "dev": "node --env-file-if-exists=.env --loader ts-node/esm src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file-if-exists=.env dist/main.js",
    "test": "pnpm run build && node --test dist/tests/*.test.js"
  },
  "dependencies": {
    "fastify": "^4.27.0",
    "postgres": "^3.4.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
