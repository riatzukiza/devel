# Clean git-state clone that auto-fork-tax mutates.
AUTO_FORK_TAX_ROOT=~/.local/share/pi-auto-fork-tax/devel
# Review model used by `pi`.
AUTO_FORK_TAX_PI_MODEL=open-hax-compat/glm-5
OPEN_HAX_OPENAI_PROXY_URL=https://ussy.promethean.rest
# Set one of these in the real env file, not in git:
# OPEN_HAX_OPENAI_PROXY_AUTH_TOKEN=...
# PROXY_AUTH_TOKEN=...
# Optional overrides:
# AUTO_FORK_TAX_BRANCH_PREFIX=pi/auto-fork-tax
# AUTO_FORK_TAX_DEFAULT_FORK_OWNER=riatzukiza
