OUR_GPUS_BIND_HOST=127.0.0.1
OUR_GPUS_API_PORT=18000
OUR_GPUS_WEB_PORT=15173

APP_ENV=dev
PROBE_TIMEOUT_SECS=5
PROBE_CONCURRENCY=200
PROBE_RETRIES=2
UPLOAD_MAX_MB=4096
ALLOWED_ORIGINS=http://127.0.0.1:15173,http://localhost:15173
LOG_LEVEL=INFO
BATCH_SIZE=1000
WORKERS=4

# Tor/Privoxy overlay defaults (used with docker-compose.tor.yml)
OUR_GPUS_TOR_HTTP_PROXY=http://privoxy:8118
OUR_GPUS_TOR_NO_PROXY=127.0.0.1,localhost,api,worker,redis,probe-sidecar,privoxy,tor
OUR_GPUS_TOR_REQUIRED=true
MASSCAN_ALLOW_DIRECT_EGRESS=false
TOR_SCAN_MAX_HOSTS=4096
TOR_SCAN_CONCURRENCY=32
OUR_GPUS_EXCLUDE_FILES=/app/excludes.conf,/app/excludes.generated.conf
