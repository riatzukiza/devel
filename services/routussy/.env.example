# Upstream z.ai API
UPSTREAM_URL=https://api.z.ai/api/paas/v4
UPSTREAM_API_KEY=your-zai-api-key-here
UPSTREAM_PREFIX=

# Image generation cost in cents (default: 1.5 = $0.015 per image)
IMAGE_COST_CENTS=1.5

# Dev user budget in cents (default: 100000 = $1000)
DEV_USER_BUDGET=100000

# Local port
ROUTUSSY_PORT=3010
